# Ollama (local — no key needed, just make sure Ollama is running)
# ollama pull mistral

# LangSmith tracing (optional — enables full agent execution traces)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=secure-financial-agent

# App settings
LOG_LEVEL=INFO
